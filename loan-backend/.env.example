# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Email Settings (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AWS Configuration (REQUIRED for KMS encryption and tokenization)
# Follow AWS_KMS_IMPLEMENTATION_GUIDE.md to set up KMS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_KMS_KEY_ID=alias/loan-encryption

# Encryption Mode: MUST be 'kms' (AWS KMS with envelope encryption)
ENCRYPTION_MODE=kms
